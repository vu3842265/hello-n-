import json
import os
from datetime import datetime

FILE_NAME = "terminal_tasks.json"

def load_data():
    if os.path.exists(FILE_NAME):
        with open(FILE_NAME, "r", encoding="utf-8") as f:
            return json.load(f)
    return []

def save_data(tasks):
    with open(FILE_NAME, "w", encoding="utf-8") as f:
        json.dump(tasks, f, ensure_ascii=False, indent=2)

def show_tasks(filter_status="all"):
    tasks = load_data()
    # Sắp xếp (Chưa xong > Đã xong), sau đó xếp theo Mức ưu tiên
    tasks.sort(key=lambda x: (x["completed"], -x["priority_val"]))
    
    print("\n--- 📋 DANH SÁCH CÔNG VIỆC ---")
    for i, t in enumerate(tasks):
        if filter_status == "pending" and t["completed"]: continue
        if filter_status == "done" and not t["completed"]: continue
        
        status = "[x]" if t["completed"] else "[ ]"
        
        # Xử lý tính toán Deadline
        try:
            dl_date = datetime.strptime(t["deadline"], "%Y-%m-%d").date()
            diff_days = (dl_date - datetime.now().date()).days
            if diff_days < 0 and not t["completed"]:
                dl_txt = f"⚠️ Quá hạn {abs(diff_days)} ngày!"
            else:
                dl_txt = f"Còn {max(0, diff_days)} ngày"
        except:
            dl_txt = "Không có hạn"
            
        priority = {3: "🔴 Cao", 2: "🟡 TB", 1: "🟢 Thấp"}[t["priority_val"]]
        
        print(f"{i+1}. {status} {t['text']} | Ưu tiên: {priority} | Hạn: {dl_txt}")
    print("------------------------------\n")

def main():
    while True:
        show_tasks()
        print("1. Thêm việc | 2. Đánh dấu xong | 3. Xóa | 4. Lọc việc chưa xong | 0. Thoát")
        chon = input("Lựa chọn của bạn: ")
        
        tasks = load_data()
        
        if chon == "1":
            text = input("Nhập công việc: ")
            date_str = input("Ngày deadline (YYYY-MM-DD): ")
            print("1: Thấp | 2: TB | 3: Cao")
            pri = int(input("Mức ưu tiên (1/2/3): "))
            
            tasks.append({
                "text": text,
                "completed": False,
                "deadline": date_str,
                "priority_val": pri
            })
            save_data(tasks)
        elif chon == "2":
            idx = int(input("Nhập STT công việc đã xong: ")) - 1
            if 0 <= idx < len(tasks):
                tasks[idx]["completed"] = not tasks[idx]["completed"]
                save_data(tasks)
        elif chon == "3":
            idx = int(input("Nhập STT muốn xóa: ")) - 1
            if 0 <= idx < len(tasks):
                tasks.pop(idx)
                save_data(tasks)
        elif chon == "4":
            show_tasks("pending")
            input("Nhấn Enter để quay lại...")
        elif chon == "0":
            break

if __name__ == "__main__":
    main()
